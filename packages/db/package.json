{
  "name": "@slotly/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./schema/zod": {
      "types": "./dist/schema/zod.d.ts",
      "default": "./dist/schema/zod.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "generate": "tsc && drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@slotly/shared": "workspace:*",
    "drizzle-orm": "^0.38.4",
    "dotenv": "^16.5.0",
    "drizzle-zod": "^0.7.0",
    "postgres": "^3.4.5",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.8.3",
    "zod": "^3.24.2"
  }
}
