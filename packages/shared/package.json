{
  "name": "@slotly/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./datetime": {
      "types": "./dist/datetime.d.ts",
      "default": "./dist/datetime.js"
    },
    "./availability": {
      "types": "./dist/availability/index.d.ts",
      "default": "./dist/availability/index.js"
    },
    "./booking": {
      "types": "./dist/booking/index.d.ts",
      "default": "./dist/booking/index.js"
    },
    "./forms": {
      "types": "./dist/forms.d.ts",
      "default": "./dist/forms.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.12.0",
    "dayjs": "^1.11.13",
    "rrule": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3"
  }
}
